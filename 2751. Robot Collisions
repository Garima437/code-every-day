class Solution {
    public List<Integer> survivedRobotsHealths(int[] positions, int[] healths, String directions) {
        int n = positions.length;
        Integer[] idx = new Integer[n];
        for (int i = 0; i < n; i++) idx[i] = i;

        // Step 1: Sort indices based on their physical positions
        Arrays.sort(idx, (a, b) -> Integer.compare(positions[a], positions[b]));

        // Step 2: Use a Stack to track robots moving Right ('R')
        Deque<Integer> stack = new ArrayDeque<>();

        for (int curr : idx) {
            if (directions.charAt(curr) == 'R') {
                stack.push(curr);
            } else {
                // Robot is moving Left ('L'), check for collisions with Right-movers
                while (!stack.isEmpty() && healths[curr] > 0) {
                    int topIndex = stack.peek();

                    if (healths[curr] > healths[topIndex]) {
                        // Left-mover is stronger
                        healths[curr] -= 1;
                        healths[topIndex] = 0;
                        stack.pop();
                    } else if (healths[curr] < healths[topIndex]) {
                        // Right-mover is stronger
                        healths[topIndex] -= 1;
                        healths[curr] = 0;
                    } else {
                        // Both have equal health
                        healths[curr] = 0;
                        healths[topIndex] = 0;
                        stack.pop();
                    }
                }
            }
        }

        // Step 3: Collect healths of robots that didn't reach 0
        List<Integer> res = new ArrayList<>();
        for (int h : healths) {
            if (h > 0) res.add(h);
        }
        return res;
    }
}
