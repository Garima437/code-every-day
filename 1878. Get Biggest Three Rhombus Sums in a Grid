class Solution {
    public int[] getBiggestThree(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        
        TreeSet<Integer> set = new TreeSet<>(Collections.reverseOrder());
        
        for (int r = 0; r < m; r++) {
            for (int c = 0; c < n; c++) {
                
                set.add(grid[r][c]);
                
               
                for (int len = 1; r - len >= 0 && r + len < m 
                        && c - len >= 0 && c + len < n; len++) {
                    
                    int sum = 0;
                    
                
                    for (int i = 0; i < len; i++)
                        sum += grid[r - len + i][c + i];
                    
                    for (int i = 0; i < len; i++)
                        sum += grid[r + i][c + len - i];
                   
                    for (int i = 0; i < len; i++)
                        sum += grid[r + len - i][c - i];
                 
                    for (int i = 0; i < len; i++)
                        sum += grid[r - i][c - len + i];
                    
                    set.add(sum);
                }
            }
        }
        
        int size = Math.min(3, set.size());
        int[] res = new int[size];
        
        int i = 0;
        for (int val : set) {
            if (i == 3) break;
            res[i++] = val;
        }
        
        return res;
    }
}
