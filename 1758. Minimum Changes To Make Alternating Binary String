class Solution {
    public int minOperations(String s) {
        int n=s.length();
        int cnt1=0;
        int cnt2=0;
        for(int i=0;i<n;i++){
            char ch=s.charAt(i);
            if(i%2==0){
                if(ch=='0') cnt1++;
                if(ch=='1') cnt2++;
            }else {
                if(ch=='1') cnt1++;
                if(ch=='0') cnt2++;
            }
        }  
        return Math.min(cnt1,cnt2); 
    }
}
