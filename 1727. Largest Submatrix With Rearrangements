class Solution {
    public int largestSubmatrix(int[][] mat) {
        int n = mat.length;
        int m = mat[0].length;
        int ans = 0;


        for(int i = 1; i < n; i++){
            for(int j = 0; j < m; j++){
                if(mat[i][j] == 1){
                    mat[i][j] += mat[i-1][j];
                }
            }
        }

     
        for(int i = 0; i < n; i++){
            Arrays.sort(mat[i]);  
            
            for(int j = 0; j < m; j++){
                ans = Math.max(ans, mat[i][j] * (m - j));
            }
        }

        return ans;
    }
}
