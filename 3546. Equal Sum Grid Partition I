class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        long[] rowSum =  new long[m];
        long[] colSum = new long[n];
        long total = 0;
        
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                rowSum[i] += grid[i][j];
                colSum[j] += grid[i][j];
                total += grid[i][j];
            }
        }
        

        if(total%2!=0) return false;

        if(fun(rowSum,total)) return true;
        if(fun(colSum,total)) return true;
        return false;
    }

    private boolean fun(long[] arr,long total){
        long l=arr[0];
        long r=total-l;
        for(int i=1;i<arr.length;i++){
            if(l==r) return true;
            else if(l>r) return false;
            l+=arr[i];
            r-=arr[i];
        }
        return false;
    }
}
